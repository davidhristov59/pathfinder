{
  "expo": {
    "name": "PathFinder",
    "slug": "pathfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PathFinder needs your location to track routes.",
        "NSLocationAlwaysUsageDescription": "PathFinder tracks your route in the background."
      },
      "bundleIdentifier": "com.anonymous.pathfinder"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PathFinder needs your location to track routes.",
          "locationAlwaysPermission": "PathFinder tracks your route in the background.",
          "locationWhenInUsePermission": "PathFinder needs location to show your position."
        }
      ]
    ],
    "scheme": "pathfinder"
  }
}
